# Database
DATABASE_URL=postgresql://user:password@host:port/database

# JWT
JWT_SECRET=your_jwt_secret_here

# Cloudinary
CLOUDINARY_CLOUD_NAME=dpxefz80w
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Africa's Talking
AT_USERNAME=your_username
AT_API_KEY=your_api_key

# MTN MoMo
# Optionnel - intégration API non activée
MOMO_SUBSCRIPTION_KEY=your_subscription_key
MOMO_API_USER=your_api_user
MOMO_API_KEY=your_api_key
MTN_WEBHOOK_SECRET=your_webhook_secret_for_hmac_validation

# MTN MoMo Disbursement (versements sortants)
MOMO_DISBURSEMENT_SUBSCRIPTION_KEY=your_disbursement_subscription_key
MOMO_DISBURSEMENT_API_USER=your_disbursement_api_user
MOMO_DISBURSEMENT_API_KEY=your_disbursement_api_key

# Airtel Money
# Optionnel - intégration API non activée
AIRTEL_CLIENT_ID=your_client_id
AIRTEL_CLIENT_SECRET=your_client_secret
AIRTEL_BASE_URL=https://openapi.airtel.africa
AIRTEL_WEBHOOK_SECRET=your_webhook_secret_for_hmac_validation

# Sentry
SENTRY_DSN=your_sentry_dsn

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Générer avec : npx web-push generate-vapid-keys

# WhatsApp WAHA
WAHA_BASE_URL=https://waha-bolamu.onrender.com
WAHA_API_KEY=

# Anthropic AI (Amina)
ANTHROPIC_API_KEY=
# Coût estimé : ~0.003 USD par consultation Amina

# Tests E2E Playwright
TEST_API_BASE=https://api.bolamu.co
TEST_PATIENT_PASSWORD=
TEST_DOCTOR_PASSWORD=
TEST_PHARMACIE_PASSWORD=
TEST_ADMIN_PASSWORD=

# Google Fit OAuth (Sprint 2 Wellness)
GOOGLE_FIT_CLIENT_ID=your_google_fit_client_id
GOOGLE_FIT_CLIENT_SECRET=your_google_fit_client_secret
GOOGLE_FIT_REDIRECT_URI=https://api.bolamu.co/api/v1/wellness/google-fit/callback

# Wellness Cron Job (Sprint 2)
# Mettre à 'true' pour activer le cron en développement
ENABLE_WELLNESS_CRON=false

# WhatsApp Web (RemoteAuth) — vestige d'une intégration whatsapp-web.js abandonnée,
# non lue par le code actuel (WAHA/GOWS via WAHA_BASE_URL + WHATSAPP_DEFAULT_SESSION).
# Valeur alignée sur le numéro WhatsApp officiel Bolamu (+242069735418) pour
# cohérence documentaire uniquement — aucun effet tant qu'aucun code ne la lit.
BOLAMU_WA_PHONE=+242069735418
