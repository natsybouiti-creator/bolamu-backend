    {
      "name": "FLOW 4 — Admin",
      "item": [
        {
          "name": "9. POST /auth/admin-login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "pm.test(\"role === 'admin'\", function () { pm.expect(json.role).to.eql('admin'); });",
                  "pm.test('accessToken présent', function () { pm.expect(json.accessToken).to.be.a('string').and.not.empty; });",
                  "if (json.accessToken) {",
                  "  pm.environment.set('admin_token', json.accessToken);",
                  "  pm.collectionVariables.set('admin_token', json.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{admin_phone}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/admin-login", "host": ["{{base_url}}"], "path": ["auth", "admin-login"] }
          }
        },
        {
          "name": "10. GET /admin/pending",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "pm.test('success true', function () { pm.expect(json.success).to.eql(true); });",
                  "pm.test('liste des comptes en attente', function () { pm.expect(json.data).to.be.an('array'); });",
                  "var first = (json.data && json.data[0]) || null;",
                  "if (first) {",
                  "  var docMap = first.documents_file_ids;",
                  "  if (docMap && typeof docMap === 'string') { try { docMap = JSON.parse(docMap); } catch (e) { docMap = {}; } }",
                  "  var firstFileId = first.doc_file_id || (docMap && (docMap.id_card || docMap.diploma || docMap.rccm || docMap.agrement));",
                  "  if (firstFileId) {",
                  "    pm.environment.set('file_id', firstFileId);",
                  "    pm.collectionVariables.set('file_id', firstFileId);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/admin/pending", "host": ["{{base_url}}"], "path": ["admin", "pending"] }
          }
        },
        {
          "name": "11. GET /admin/documents/:fileId",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('fichier servi (Content-Type présent)', function () { pm.expect(pm.response.headers.get('Content-Type')).to.be.a('string').and.not.empty; });",
                  "pm.test('corps non vide', function () { pm.expect(pm.response.responseSize).to.be.above(0); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/admin/documents/{{file_id}}", "host": ["{{base_url}}"], "path": ["admin", "documents", "{{file_id}}"] }
          }
        }
