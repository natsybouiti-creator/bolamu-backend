              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 ou 201', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "var json = pm.response.json();",
                  "pm.test('success true', function () { pm.expect(json.success).to.eql(true); });",
